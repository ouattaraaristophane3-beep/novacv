# URL et clé publique (Settings → API → Project URL / anon public)
VITE_SUPABASE_URL=https://votre-ref.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon

# Pour les migrations (Settings → Database → Database password)
# Option A — recommandé avec npm run db:migrate :
SUPABASE_DB_PASSWORD=

# Option B — URL complète PostgreSQL :
# DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@db.votre-ref.supabase.co:5432/postgres

# Optionnel — CLI Supabase (supabase link / db push)
# SUPABASE_ACCESS_TOKEN=
